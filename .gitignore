# === macOS App (Xcode / Swift) ===

# Build artifacts
build/
DerivedData/
*.xcodeproj/xcuserdata/
*.xcodeproj/project.xcworkspace/xcuserdata/
*.xcworkspace/xcuserdata/

# Xcode state
*.xcodeproj/project.xcworkspace/xcshareddata/IDEWorkspaceChecks.plist
*.xcodeproj/xcshareddata/xcschemes/xcschememanagement.plist

# Archives & exports
*.ipa
*.dSYM.zip
*.dSYM
*.app

# Code signing
*.mobileprovision
*.provisionprofile

# Xcode playground
timeline.xctimeline
playground.xcworkspace

# SPM
.swiftpm/
Package.resolved

# XcodeGen
# Keep project.yml, ignore generated project internals
# (xcodeproj itself is committed if not using XcodeGen exclusively)

# === ESP-IDF Firmware ===

# Build output
firmware/build/

# sdkconfig is generated from sdkconfig.defaults — keep defaults, ignore generated
firmware/sdkconfig.old

# Managed components cache (can be re-fetched)
firmware/managed_components/

# Dependencies lock (regenerated by idf.py)
firmware/dependencies.lock

